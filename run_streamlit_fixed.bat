@echo off&#10;REM ============================================&#10;REM Fixed Streamlit Launcher - Works in PowerShell/cmd&#10;REM Handles: venv, deps install, browser open&#10;REM Usage: .\run_streamlit_fixed.bat (from root)&#10;REM ============================================&#10;&#10;REM Change to script directory&#10;cd /d "%~dp0"&#10;&#10;REM Activate virtual environment if exists&#10;if exist venv\\Scripts\\activate.bat (&#10;    echo Activating venv...&#10;    call venv\\Scripts\\activate.bat&#10;) else (&#10;    echo No venv found, using global Python&#10;)&#10;&#10;REM Check and install requirements if streamlit missing&#10;streamlit --version ^>nul 2^>1&#10;if errorlevel 1 (&#10;    echo Installing requirements...&#10;    pip install -r requirements.txt&#10;    pip install streamlit plotly pandas scikit-learn&#10;) else (&#10;    echo Streamlit ready (v1.55.0 detected)&#10;)&#10;&#10;REM Verify data file&#10;if exist "data\\sample_user_behavior_1000.csv" (&#10;    echo Data file OK&#10;) else (&#10;    echo WARNING: data\\sample_user_behavior_1000.csv missing!&#10;)&#10;&#10;echo.&#10;echo 🚀 Starting Intelligent Streamlit Dashboard...&#10;echo 📱 Open your browser to: http://localhost:8501&#10;echo.&#10;&#10;REM Open browser ^&amp; start Streamlit (non-blocking)&#10;start http://localhost:8501&#10;streamlit run streamlit_intelligent_dashboard.py --server.headless true --server.port 8501 --server.address 127.0.0.1&#10;&#10;echo.&#10;echo Press any key to exit...&#10;pause ^>nul
