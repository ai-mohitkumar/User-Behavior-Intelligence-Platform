@echo off&#10;REM ==================== FULL STACK LAUNCHER ====================&#10;REM Backend (FastAPI): localhost:8000&#10;REM Frontend (React): localhost:3000&#10;REM Streamlit: localhost:8501&#10;REM Works in PowerShell/cmd&#10;REM =============================================================&#10;&#10;REM Project root&#10;cd /d "%~dp0"&#10;&#10;REM Venv&#10;if exist venv\\Scripts\\activate.bat (&#10;    call venv\\Scripts\\activate.bat&#10;)&#10;&#10;REM Install deps&#10;pip install -r requirements.txt ^>nul 2^>1&#10;&#10;echo 🚀 Launching Full Stack...&#10;echo.&#10;&#10;REM Backend FastAPI&#10;start "Backend FastAPI" cmd /k "cd UserBehaviorApp\\backend ^&amp; uvicorn main:app --reload --host 127.0.0.1 --port 8000"&#10;timeout /t 3 /nobreak ^>nul&#10;&#10;REM Frontend React&#10;start "React Frontend" cmd /k "cd UserBehaviorApp\\frontend ^&amp; npm start"&#10;timeout /t 3 /nobreak ^>nul&#10;&#10;REM Streamlit Dashboard&#10;start "Streamlit Dashboard" cmd /k "streamlit run streamlit_intelligent_dashboard.py --server.port 8501 --server.headless true"&#10;&#10;echo.&#10;echo ✅ Full Stack Running!&#10;echo Backend: http://localhost:8000/docs&#10;echo Frontend: http://localhost:3000&#10;echo Dashboard: http://localhost:8501&#10;echo.&#10;echo Press any key to open browsers...&#10;pause ^>nul&#10;&#10;start http://localhost:8000/docs&#10;start http://localhost:3000&#10;start http://localhost:8501&#10;&#10;pause
